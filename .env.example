# Copy to .env and fill in values. Never commit .env.

# --- LLM (use one provider; agent prefers OpenAI if OPENAI_API_KEY is set) ---
OPENAI_API_KEY=
GOOGLE_API_KEY=

# openai | gemini
LLM_PROVIDER=openai
LLM_MODEL_OPENAI=gpt-4o
LLM_MODEL_GEMINI=gemini-1.5-pro

# --- Optional: web search for oil / energy context (OilPriceIndicatorTool) ---
TAVILY_API_KEY=

# --- Optional tuning ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
