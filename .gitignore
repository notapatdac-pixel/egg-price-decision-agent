# Course / project: exclude .env, node_modules, __pycache__ (among others below).

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# Environment and secrets
.env
.env.local
.env.*.local

# Node (if you add a JS/TS web UI or tooling)
node_modules/

